# Copy these values into backend/.env (do not commit backend/.env).
# The API key is used only by the backend for AI image generation and fabric vision.

# Required to enable /api/designer/generate-fashion-image
OPENAI_API_KEY=replace_with_your_openai_api_key
OPENAI_IMAGE_MODEL=gpt-image-1-mini

# Optional: use a vision-capable model for fabric checks when configured by the service.
OPENAI_VISION_MODEL=gpt-4o-mini

# Existing backend requirements: keep your real Supabase credentials in backend/.env
SUPABASE_URL=replace_with_your_supabase_url
SUPABASE_SECRET_KEY=replace_with_your_supabase_service_role_key
